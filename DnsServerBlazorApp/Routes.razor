<Router AppAssembly="@typeof(Routes).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(DnsServerBlazorApp.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(DnsServerBlazorApp.Layout.MainLayout)">
            <MudText Typo="Typo.h6">Page not found.</MudText>
        </LayoutView>
    </NotFound>
</Router>
