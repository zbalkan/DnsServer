@* Dropdown for selecting a cluster node – shown next to each tab's toolbar.
   Mirrors the .cluster-node-dropdown selects in the original HTML.         *@
@inject SessionService SessionService

@if (_items.Count > 1)
{
    <MudSelect T="string" Value="@Value" ValueChanged="OnValueChanged"
               Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
               Style="max-width:220px;" Class="dns-cluster-select"
               Label="Node">
        @foreach (var item in _items)
        {
            <MudSelectItem Value="@item.Value">@item.Label</MudSelectItem>
        }
    </MudSelect>
}

@code {
    /// <summary>Currently-selected node name or "cluster".</summary>
    [Parameter] public string  Value        { get; set; } = string.Empty;
    [Parameter] public bool    IncludeAll   { get; set; } = true;    // "cluster" option
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private record NodeItem(string Value, string Label);
    private List<NodeItem> _items = [];

    protected override async Task OnInitializedAsync()
    {
        var defaultValue = Build();
        if (defaultValue is not null)
            await ValueChanged.InvokeAsync(defaultValue);
    }

    protected override async Task OnParametersSetAsync()
    {
        var defaultValue = Build();
        if (defaultValue is not null)
            await ValueChanged.InvokeAsync(defaultValue);
    }

    /// <summary>Rebuilds _items and returns the default value if the current Value is not in the list.</summary>
    private string? Build()
    {
        _items = [];
        if (IncludeAll)
            _items.Add(new("cluster", "All Nodes (cluster)"));

        foreach (var n in SessionService.ClusterNodes)
            _items.Add(new(n.Name, n.IsPrimary ? $"{n.Name} (primary)" : n.Name));

        if (_items.Count > 0 && !_items.Any(i => i.Value == Value))
            return _items[0].Value;

        return null;
    }

    private Task OnValueChanged(string v) => ValueChanged.InvokeAsync(v);
}
