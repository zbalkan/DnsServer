@inject ApiService Api
@inject ISnackbar  Snackbar

<MudDialog>
    <DialogContent>
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
                      CloseIconClicked="@(() => _error = null)">@_error</MudAlert>
        }
        <MudTextField @bind-Value="_displayName" Label="Display Name" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Class="mb-2" />
        <MudCheckBox @bind-Value="_disabled" Label="Account Disabled" Dense="true" Class="mb-2" />

        <MudDivider Class="mb-2" />
        <MudText Typo="Typo.caption" Class="mb-1">Reset Password (leave blank to keep current)</MudText>
        <MudTextField @bind-Value="_newPass" Label="New Password" Variant="Variant.Outlined"
                      Margin="Margin.Dense" InputType="InputType.Password" Class="mb-2" />
        <MudTextField @bind-Value="_confirmPass" Label="Confirm Password" Variant="Variant.Outlined"
                      Margin="Margin.Dense" InputType="InputType.Password" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="MudDialog.Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@_busy" OnClick="SaveAsync">
            @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter, EditorRequired] public UserInfo User { get; set; } = null!;

    private string  _displayName = string.Empty;
    private bool    _disabled;
    private string  _newPass     = string.Empty;
    private string  _confirmPass = string.Empty;
    private string? _error;
    private bool    _busy;

    protected override void OnParametersSet()
    {
        _displayName = User.DisplayName ?? string.Empty;
        _disabled    = User.Disabled;
    }

    private async Task SaveAsync()
    {
        if (!string.IsNullOrEmpty(_newPass) && _newPass != _confirmPass)
        { _error = "Passwords do not match."; return; }

        _busy = true;
        var form = new Dictionary<string, string>
        {
            ["user"]        = User.Username ?? "",
            ["displayName"] = _displayName,
            ["disabled"]    = _disabled ? "true" : "false",
        };
        if (!string.IsNullOrEmpty(_newPass))
            form["newPass"] = _newPass;

        var result = await Api.PostAsync<object>("api/user/update", form);
        _busy = false;

        if (result.IsOk)
        {
            Snackbar.Add("User updated.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
            _error = result.DisplayError;
    }
}
