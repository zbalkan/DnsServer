@inject ApiService     Api
@inject SessionService SessionService
@inject ISnackbar      Snackbar

<MudDialog>
    <DialogContent>
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
                      CloseIconClicked="@(() => _error = null)">@_error</MudAlert>
        }

        @if (SessionService.TotpEnabled)
        {
            <MudAlert Severity="Severity.Info" Class="mb-3">
                Two-factor authentication is currently <strong>enabled</strong>.
                Disabling it will allow login without a TOTP code.
            </MudAlert>
        }
        else if (_qrCodeImage is null)
        {
            <MudText Typo="Typo.body2" Class="mb-2">
                Enable two-factor authentication using an authenticator app.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@_busy" OnClick="SetupAsync">
                @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Setup 2FA
            </MudButton>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mb-2">
                Scan this QR code with your authenticator app, then enter the code below to confirm.
            </MudText>
            <div style="text-align:center;margin:12px 0;">
                <img src="@($"data:image/png;base64,{_qrCodeImage}")" alt="QR Code" style="max-width:200px;" />
            </div>
            <MudTextField @bind-Value="_secret" Label="Secret Key" Variant="Variant.Outlined"
                          Margin="Margin.Dense" ReadOnly="true" Class="mb-2" />
            <MudTextField @bind-Value="_totp" Label="TOTP Code" Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          OnKeyUp="@(async e => { if(e.Key=="Enter") await EnableAsync(); })" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="MudDialog.Cancel">Cancel</MudButton>
        @if (SessionService.TotpEnabled)
        {
            <MudButton Color="Color.Error" Variant="Variant.Filled"
                       Disabled="@_busy" OnClick="DisableAsync">
                @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Disable 2FA
            </MudButton>
        }
        else if (_qrCodeImage is not null)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       Disabled="@_busy" OnClick="EnableAsync">
                @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Enable 2FA
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private string? _qrCodeImage; // base64 PNG returned by api/user/2fa/init
    private string? _secret;
    private string  _totp  = string.Empty;
    private string? _error;
    private bool    _busy;

    private async Task SetupAsync()
    {
        _busy = true;
        var result = await Api.GetAsync<Models.Auth.TotpSetupResponse>("api/user/2fa/init");
        _busy = false;

        if (result.IsOk && result.Data is not null)
        {
            _secret      = result.Data.Secret;
            _qrCodeImage = result.Data.QrCodePngImage;
        }
        else
            _error = result.DisplayError;
    }

    private async Task EnableAsync()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(_totp)) { _error = "Enter the TOTP code."; return; }
        _busy = true;
        var form = new Dictionary<string, string> { ["totp"] = _totp };
        var result = await Api.PostAsync<object>("api/user/2fa/enable", form);
        _busy = false;

        if (result.IsOk)
        {
            SessionService.UpdateTotpEnabled(true);
            Snackbar.Add("2FA enabled.", Severity.Success);
            MudDialog.Close();
        }
        else
            _error = result.DisplayError;
    }

    private async Task DisableAsync()
    {
        _busy = true;
        var result = await Api.GetAsync<object>("api/user/2fa/disable");
        _busy = false;

        if (result.IsOk)
        {
            SessionService.UpdateTotpEnabled(false);
            Snackbar.Add("2FA disabled.", Severity.Success);
            MudDialog.Close();
        }
        else
            _error = result.DisplayError;
    }
}
