@inject ApiService Api
@inject ISnackbar  Snackbar

<MudDialog>
    <DialogContent>
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
                      CloseIconClicked="@(() => _error = null)">@_error</MudAlert>
        }
        <MudText Typo="Typo.body2" Class="mb-3">
            Install a DNS app from a URL or upload a package file (.zip).
        </MudText>
        <MudTabs Elevation="0" @bind-ActivePanelIndex="_tabIndex">
            <MudTabPanel Text="URL">
                <div Class="pt-3">
                    <MudTextField @bind-Value="_name" Label="App Name" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Class="mb-2" />
                    <MudTextField @bind-Value="_url" Label="Package URL" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Upload">
                <div Class="pt-3">
                    <MudText Typo="Typo.caption">Upload support requires the server-side endpoint.</MudText>
                    <MudTextField @bind-Value="_name" Label="App Name" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Class="mb-2 mt-2" />
                    <InputFile OnChange="OnFileSelected" accept=".zip" />
                </div>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="MudDialog.Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@_busy" OnClick="InstallAsync">
            @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Install
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string Node { get; set; } = "cluster";

    private int     _tabIndex;
    private string  _name  = string.Empty;
    private string  _url   = string.Empty;
    private string? _error;
    private bool    _busy;
    private IBrowserFile? _file;

    private void OnFileSelected(InputFileChangeEventArgs e) => _file = e.File;

    private async Task InstallAsync()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(_name)) { _error = "App name is required."; return; }
        _busy = true;
        try
        {
            ApiResult<object> result;

            if (_tabIndex == 0)
            {
                if (string.IsNullOrWhiteSpace(_url)) { _error = "URL is required."; return; }
                var form = new Dictionary<string, string>
                {
                    ["name"] = _name,
                    ["url"]  = _url,
                    ["node"] = Node,
                };
                result = await Api.PostAsync<object>("api/apps/downloadAndInstall", form);
            }
            else
            {
                if (_file is null) { _error = "Select a file."; return; }
                var mp = new MultipartFormDataContent();
                mp.Add(new StringContent(_name), "name");
                mp.Add(new StringContent(Node),  "node");
                await using var stream = _file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
                mp.Add(new StreamContent(stream), "appFile", _file.Name);
                result = await Api.PostMultipartAsync<object>("api/apps/install", mp);
            }

            if (result.IsOk)
            {
                Snackbar.Add($"'{_name}' installed.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
                _error = result.DisplayError;
        }
        finally
        {
            _busy = false;
        }
    }
}
