@inject ApiService     Api
@inject SessionService SessionService
@inject ISnackbar      Snackbar

<MudDialog>
    <DialogContent>
        @if (ForceChange)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-3">
                You are using the default password. Please change it now.
            </MudAlert>
        }
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
                      CloseIconClicked="@(() => _error = null)">@_error</MudAlert>
        }
        <MudTextField @bind-Value="_currentPass" Label="Current Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                      Disabled="@_busy" />
        <MudTextField @bind-Value="_newPass" Label="New Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                      Disabled="@_busy" />
        <MudTextField @bind-Value="_confirmPass" Label="Confirm New Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Disabled="@_busy"
                      OnKeyUp="@(async e => { if(e.Key=="Enter") await SaveAsync(); })" />
    </DialogContent>
    <DialogActions>
        @if (!ForceChange)
        {
            <MudButton OnClick="MudDialog.Cancel">Cancel</MudButton>
        }
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@_busy" OnClick="SaveAsync">
            @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Change Password
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public bool ForceChange { get; set; }

    private string  _currentPass = string.Empty;
    private string  _newPass     = string.Empty;
    private string  _confirmPass = string.Empty;
    private string? _error;
    private bool    _busy;

    private async Task SaveAsync()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(_currentPass)) { _error = "Enter current password."; return; }
        if (string.IsNullOrWhiteSpace(_newPass))     { _error = "Enter new password."; return; }
        if (_newPass != _confirmPass)                { _error = "Passwords do not match."; return; }

        _busy = true;
        try
        {
            var form = new Dictionary<string, string>
            {
                ["user"]    = SessionService.Username,
                ["pass"]    = _currentPass,
                ["newPass"] = _newPass,
            };
            var result = await Api.PostAsync<object>("api/user/changePassword", form);

            if (result.IsOk)
            {
                Snackbar.Add("Password changed successfully.", Severity.Success);
                MudDialog.Close();
            }
            else
            {
                _error = result.DisplayError;
            }
        }
        finally
        {
            _busy = false;
        }
    }
}
