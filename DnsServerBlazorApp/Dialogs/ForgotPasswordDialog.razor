@inject ApiService Api
@inject ISnackbar   Snackbar

<MudDialog>
    <DialogContent>
        @if (_sent)
        {
            <MudAlert Severity="Severity.Success">
                If the username exists, a password reset e-mail has been sent.
            </MudAlert>
        }
        else
        {
            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
                          CloseIconClicked="@(() => _error = null)">@_error</MudAlert>
            }
            <MudTextField @bind-Value="_username" Label="Username"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Disabled="@_busy"
                          OnKeyUp="@(async e => { if(e.Key=="Enter") await SendAsync(); })" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="MudDialog.Cancel">Close</MudButton>
        @if (!_sent)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       Disabled="@_busy" OnClick="SendAsync">
                @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Send Reset Link
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private string  _username = string.Empty;
    private string? _error;
    private bool    _busy;
    private bool    _sent;

    private async Task SendAsync()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(_username))
        { _error = "Please enter a username."; return; }

        _busy = true;
        try
        {
            var form = new Dictionary<string, string> { ["user"] = _username };
            var result = await Api.PostAsync<object>("api/user/forgotPassword", form);

            if (result.IsOk)
                _sent = true;
            else
                _error = result.DisplayError;
        }
        finally
        {
            _busy = false;
        }
    }
}
