@inject ApiService     Api
@inject SessionService SessionService
@inject IDialogService DialogService
@inject ISnackbar      Snackbar

@* ── Breadcrumb / toolbar ── *@
<div class="dns-toolbar">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => OnClose.InvokeAsync())"
                   Title="Back to zones" />
    <MudText Typo="Typo.h6" Style="flex:1">@Zone.Name</MudText>
    <MudChip T="string" Size="Size.Small" Color="@DnsStyling.ZoneTypeColor(Zone.Type)"
             Variant="Variant.Filled">@Zone.Type</MudChip>

    @if (SessionService.CanModify("Zones"))
    {
        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddRecordAsync">Add Record</MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Sync"
                   OnClick="ResyncAsync">Resync</MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Settings"
                   OnClick="ZoneOptionsAsync">Options</MudButton>
        @if (Zone.Type == "Primary")
        {
            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Security"
                       OnClick="DnssecAsync">DNSSEC</MudButton>
        }
    }
</div>

@* ── Filter bar ── *@
<div class="dns-toolbar">
    <MudTextField @bind-Value="_search" Label="Filter records" Variant="Variant.Outlined"
                  Margin="Margin.Dense" Style="max-width:280px;"
                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" DebounceInterval="300"
                  OnDebounceIntervalElapsed="UpdateFilteredRecords" />
    <MudSelect T="string" Value="@_typeFilter" ValueChanged="OnTypeFilterChanged"
               Label="Type" Variant="Variant.Outlined"
               Margin="Margin.Dense" Style="max-width:140px;">
        <MudSelectItem Value="@("")">All</MudSelectItem>
        @foreach (var t in _recordTypes)
        { <MudSelectItem Value="@t">@t</MudSelectItem> }
    </MudSelect>
</div>

@if (_loading)
{
    <div style="display:flex;justify-content:center;padding:40px;">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </div>
}
else
{
    <MudTable Items="@_filteredRecords" Dense="true" Hover="true" Elevation="1"
              FixedHeader="true" Height="calc(100vh - 290px)">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>TTL</MudTh>
            <MudTh>Data</MudTh>
            @if (SessionService.CanModify("Zones"))
            {
                <MudTh></MudTh>
            }
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Type">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Color="Color.Info">@context.Type</MudChip>
            </MudTd>
            <MudTd DataLabel="TTL">@context.TtlValue</MudTd>
            <MudTd DataLabel="Data" Style="max-width:400px;word-break:break-all;">
                @context.RData?.ToString()
            </MudTd>
            @if (SessionService.CanModify("Zones"))
            {
                <MudTd Style="text-align:right;white-space:nowrap;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   OnClick="@(() => EditRecordAsync(context))"
                                   Title="Edit record" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => DeleteRecordAsync(context))"
                                   Title="Delete record" />
                </MudTd>
            }
        </RowTemplate>
    </MudTable>

    <MudText Typo="Typo.caption" Class="mt-1">
        @_filteredRecords.Count record(s)
        @if (!string.IsNullOrEmpty(_search) || !string.IsNullOrEmpty(_typeFilter))
        { <span> (filtered from @_records.Count)</span> }
    </MudText>
}

@code {
    [Parameter, EditorRequired] public ZoneInfo Zone   { get; set; } = null!;
    [Parameter]                 public string   Node   { get; set; } = "cluster";
    [Parameter]                 public EventCallback OnClose { get; set; }

    private static readonly string[] _recordTypes =
        ["A", "AAAA", "CNAME", "MX", "NS", "PTR", "SOA", "SRV", "TXT",
         "CAA", "NAPTR", "ANAME", "FWD", "APP", "HTTPS", "SVCB", "TLSA",
         "SSHFP", "DNSKEY", "DS", "RRSIG", "NSEC", "NSEC3"];

    private bool             _loading = true;
    private string           _search     = string.Empty;
    private string           _typeFilter = string.Empty;
    private List<ZoneRecord> _records    = [];
    private List<ZoneRecord> _filteredRecords = [];

    private void UpdateFilteredRecords()
    {
        _filteredRecords = _records
            .Where(r => (string.IsNullOrEmpty(_search) ||
                         r.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                         r.RData?.ToString()?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true) &&
                        (string.IsNullOrEmpty(_typeFilter) || r.Type == _typeFilter))
            .ToList();
    }

    private void OnTypeFilterChanged(string value) { _typeFilter = value; UpdateFilteredRecords(); }

    protected override async Task OnParametersSetAsync() => await LoadRecordsAsync();

    private async Task LoadRecordsAsync()
    {
        _loading = true;
        var url = $"api/zones/records/get?zone={Uri.EscapeDataString(Zone.Name)}" +
                  $"&node={Uri.EscapeDataString(Node)}";
        var result = await Api.GetAsync<ZoneRecordListResponse>(url);
        _loading = false;

        if (result.IsOk && result.Data?.Records is { } list)
        {
            _records = list;
            UpdateFilteredRecords();
        }
        else
            Snackbar.Add(result.DisplayError, Severity.Error);
    }

    private async Task AddRecordAsync()
    {
        var p = new DialogParameters { ["Zone"] = Zone.Name, ["Node"] = Node };
        var d = await DialogService.ShowAsync<Dialogs.AddEditRecordDialog>("Add Record", p,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var r = await d.Result;
        if (r is { Canceled: false })
            await LoadRecordsAsync();
    }

    private async Task EditRecordAsync(ZoneRecord record)
    {
        var p = new DialogParameters
        {
            ["Zone"]   = Zone.Name,
            ["Node"]   = Node,
            ["Record"] = record,
        };
        var d = await DialogService.ShowAsync<Dialogs.AddEditRecordDialog>("Edit Record", p,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var r = await d.Result;
        if (r is { Canceled: false })
            await LoadRecordsAsync();
    }

    private async Task DeleteRecordAsync(ZoneRecord record)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Delete Record",
            $"Delete {record.Type} record '{record.Name}'?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirm is not true) return;

        var form = new Dictionary<string, string>
        {
            ["zone"]  = Zone.Name,
            ["type"]  = record.Type,
            ["domain"] = record.Name,
            ["node"]  = Node,
        };
        var res = await Api.PostAsync<object>("api/zones/records/delete", form);
        if (res.IsOk)
        {
            _records.Remove(record);
            UpdateFilteredRecords();
            Snackbar.Add("Record deleted.", Severity.Success);
        }
        else
            Snackbar.Add(res.DisplayError, Severity.Error);
    }

    private async Task ResyncAsync()
    {
        var form = new Dictionary<string, string> { ["zone"] = Zone.Name, ["node"] = Node };
        var res = await Api.PostAsync<object>("api/zones/resync", form);
        if (res.IsOk) Snackbar.Add("Zone resync triggered.", Severity.Success);
        else          Snackbar.Add(res.DisplayError, Severity.Error);
    }

    private async Task ZoneOptionsAsync()
    {
        var p = new DialogParameters { ["Zone"] = Zone.Name, ["Node"] = Node };
        await DialogService.ShowAsync<Dialogs.ZoneOptionsDialog>($"{Zone.Name} — Options", p,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    private async Task DnssecAsync()
    {
        var p = new DialogParameters { ["Zone"] = Zone.Name, ["Node"] = Node };
        await DialogService.ShowAsync<Dialogs.DnssecPropertiesDialog>($"{Zone.Name} — DNSSEC", p,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }
}
