@inject ApiService      Api
@inject SessionService  SessionService
@inject IDialogService  DialogService
@inject ISnackbar       Snackbar
@implements IDisposable

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap" Spacing="1" Class="mb-2">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.DateRange"
               OnClick="OpenCustomRangeDialogAsync">
        @GetSelectedRangeLabel()
    </MudButton>

    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
        @if (_range != "lastHour")
        {
            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="UseLastHourAsync">
                Use Last Hour
            </MudButton>
        }
        <ClusterNodeSelect Value="@_node" ValueChanged="OnNodeChangedAsync" />
    </MudStack>
</MudStack>

@if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">@_loadError</MudAlert>
}

@if (_loading && _response is null)
{
    <MudGrid Spacing="2">
        @for (var i = 0; i < 11; i++)
        {
            <MudItem xs="6" sm="4" md="3" lg="2" xl="1">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="62px" />
            </MudItem>
        }

        <MudItem xs="12" xl="8"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="420px" /></MudItem>
        <MudItem xs="12" xl="4"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="420px" /></MudItem>
        <MudItem xs="12" md="6" xl="4"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="290px" /></MudItem>
        <MudItem xs="12" md="6" xl="4"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="290px" /></MudItem>
        <MudItem xs="12" md="6" xl="4"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="290px" /></MudItem>
        <MudItem xs="12" xl="6"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="330px" /></MudItem>
        <MudItem xs="12" xl="6"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="330px" /></MudItem>
    </MudGrid>
}
else if (_response?.Stats is not null)
{
    var stats = _response.Stats;

    <div class="dns-stats-strip">
        <StatsCard StatKey="TotalQueries" Title="Total Queries" Value="@stats.TotalQueries" ShowPercent="false" />
        <StatsCard StatKey="TotalNoError" Title="No Error" Value="@stats.TotalNoError" ShowPercent="true" Percent="@stats.NoErrorPct" />
        <StatsCard StatKey="ServerFailure" Title="Server Failure" Value="@stats.TotalServerFailure" ShowPercent="true" Percent="@stats.ServerFailurePct" />
        <StatsCard StatKey="NxDomain" Title="NX Domain" Value="@stats.TotalNxDomain" ShowPercent="true" Percent="@stats.NxDomainPct" />
        <StatsCard StatKey="Refused" Title="Refused" Value="@stats.TotalRefused" ShowPercent="true" Percent="@stats.RefusedPct" />
        <StatsCard StatKey="AuthHit" Title="Authoritative" Value="@stats.TotalAuthHit" ShowPercent="true" Percent="@stats.AuthHitPct" />
        <StatsCard StatKey="Recursions" Title="Recursive" Value="@stats.TotalRecursions" ShowPercent="true" Percent="@stats.RecursionsPct" />
        <StatsCard StatKey="CacheHit" Title="Cached" Value="@stats.TotalCacheHit" ShowPercent="true" Percent="@stats.CacheHitPct" />
        <StatsCard StatKey="Blocked" Title="Blocked" Value="@stats.TotalBlocked" ShowPercent="true" Percent="@stats.BlockedPct" />
        <StatsCard StatKey="Dropped" Title="Dropped" Value="@stats.TotalDropped" ShowPercent="true" Percent="@stats.DroppedPct" />
        <StatsCard StatKey="Clients" Title="Clients" Value="@stats.TotalClients" ShowPercent="false" />
    </div>

    <MudGrid Spacing="2" Class="dns-dashboard-grid">
        <MudItem xs="12">
            <div class="dns-zone-stats-strip">
                <ZoneStatsCard Title="Zones" Value="@stats.Zones" />
                <ZoneStatsCard Title="Cache" Value="@stats.CachedEntries" />
                <ZoneStatsCard Title="Allowed" Value="@stats.AllowedZones" />
                <ZoneStatsCard Title="Blocked" Value="@stats.BlockedZones" />
                <ZoneStatsCard Title="Allow List" Value="@stats.AllowListZones" />
                <ZoneStatsCard Title="Block List" Value="@stats.BlockListZones" />
            </div>
        </MudItem>

        <MudItem xs="12" xl="8">
            <MudPaper Elevation="1" Class="pa-2 dns-dashboard-panel dns-dashboard-main-chart">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Query Trends</MudText>
                @if (_lineLabels.Length > 0 && _lineSeries.Count > 0)
                {
                    <MudChart T="double" ChartType="ChartType.Line"
                              ChartSeries="@_lineSeries"
                              xAxisLabels="@_lineLabels"
                              Height="380px"
                              Width="100%"
                              ChartOptions="@_lineOptions" />
                }
                else
                {
                    <MudText Class="pa-6" Align="Align.Center" Typo="Typo.body2">No data for selected range.</MudText>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" xl="4">
            <MudPaper Elevation="1" Class="dns-dashboard-panel">
                <div class="dns-panel-header-row pa-2">
                    <MudText Typo="Typo.subtitle2">Top Clients</MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined"
                               OnClick="@(() => ShowTopStatsAsync("TopClients"))">More</MudButton>
                </div>
                <MudTable Items="@(_response?.TopClients ?? [])" Dense="true" Hover="true" Elevation="0" FixedHeader="true" Height="380px">
                    <HeaderContent>
                        <MudTh>Client</MudTh>
                        <MudTh style="text-align:right;">Queries</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Client">@context.Name</MudTd>
                        <MudTd DataLabel="Queries" style="text-align:right;">@context.Hits.ToString("N0")</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Search" Size="Size.Small"
                                           OnClick="@(() => QueryClient(context.Name))"
                                           title="Query this client" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4" Typo="Typo.body2">No data for selected range.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6" xl="4">
            <MudPaper Elevation="1" Class="pa-2 dns-dashboard-panel">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Response Types</MudText>
                @if (HasPieData(_pie1Data, _pie1Labels))
                {
                    <MudChart ChartType="ChartType.Pie"
                              ChartSeries="@_pie1Data.AsChartDataSet()" ChartLabels="@_pie1Labels"
                              Height="250px" Width="100%" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="ma-2">No data for selected range.</MudAlert>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6" xl="4">
            <MudPaper Elevation="1" Class="pa-2 dns-dashboard-panel">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Query Types</MudText>
                @if (HasPieData(_pie2Data, _pie2Labels))
                {
                    <MudChart ChartType="ChartType.Pie"
                              ChartSeries="@_pie2Data.AsChartDataSet()" ChartLabels="@_pie2Labels"
                              Height="250px" Width="100%" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="ma-2">No data for selected range.</MudAlert>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6" xl="4">
            <MudPaper Elevation="1" Class="pa-2 dns-dashboard-panel">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Protocols</MudText>
                @if (HasPieData(_pie3Data, _pie3Labels))
                {
                    <MudChart ChartType="ChartType.Pie"
                              ChartSeries="@_pie3Data.AsChartDataSet()" ChartLabels="@_pie3Labels"
                              Height="250px" Width="100%" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="ma-2">No data for selected range.</MudAlert>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" xl="6">
            <MudPaper Elevation="1" Class="dns-dashboard-panel">
                <div class="dns-panel-header-row pa-2">
                    <MudText Typo="Typo.subtitle2">Top Domains</MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined"
                               OnClick="@(() => ShowTopStatsAsync("TopDomains"))">More</MudButton>
                </div>
                <MudTable Items="@(_response?.TopDomains ?? [])" Dense="true" Hover="true" Elevation="0" FixedHeader="true" Height="300px">
                    <HeaderContent>
                        <MudTh>Domain</MudTh>
                        <MudTh style="text-align:right;">Hits</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Domain">@DisplayName(context)</MudTd>
                        <MudTd DataLabel="Hits" style="text-align:right;">@context.Hits.ToString("N0")</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Search" Size="Size.Small"
                                           OnClick="@(() => QueryDomain(context.Name))"
                                           title="Query this domain" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4" Typo="Typo.body2">No data for selected range.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" xl="6">
            <MudPaper Elevation="1" Class="dns-dashboard-panel">
                <div class="dns-panel-header-row pa-2">
                    <MudText Typo="Typo.subtitle2">Top Blocked Domains</MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined"
                               OnClick="@(() => ShowTopStatsAsync("TopBlockedDomains"))">More</MudButton>
                </div>
                <MudTable Items="@(_response?.TopBlockedDomains ?? [])" Dense="true" Hover="true" Elevation="0" FixedHeader="true" Height="300px">
                    <HeaderContent>
                        <MudTh>Domain</MudTh>
                        <MudTh style="text-align:right;">Hits</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Domain">@DisplayName(context)</MudTd>
                        <MudTd DataLabel="Hits" style="text-align:right;">@context.Hits.ToString("N0")</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Search" Size="Size.Small"
                                           OnClick="@(() => QueryDomain(context.Name))"
                                           title="Query this domain" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4" Typo="Typo.body2">No data for selected range.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private string _range = "lastHour";
    private string _node = "cluster";
    private DateTime? _customStart;
    private DateTime? _customEnd;

    private bool _loading = true;
    private bool _refreshing;
    private string? _loadError;

    private DashboardStatsResponse? _response;
    private CancellationTokenSource? _loadCts;

    private List<ChartSeries<double>> _lineSeries = [];
    private string[] _lineLabels = [];
    private ChartOptions _lineOptions = new();

    private double[] _pie1Data = [];
    private string[] _pie1Labels = [];
    private double[] _pie2Data = [];
    private string[] _pie2Labels = [];
    private double[] _pie3Data = [];
    private string[] _pie3Labels = [];

    protected override async Task OnInitializedAsync()
        => await RefreshAsync();

    private async Task OnNodeChangedAsync(string value)
    {
        _node = value;
        await RefreshAsync();
    }

    public async Task SilentRefreshAsync()
    {
        if (_refreshing || _range != "lastHour")
            return;

        _refreshing = true;
        try
        {
            await LoadDataAsync(showLoader: false);
        }
        finally
        {
            _refreshing = false;
        }
    }

    private async Task UseLastHourAsync()
    {
        _range = "lastHour";
        _customStart = null;
        _customEnd = null;
        await RefreshAsync();
    }

    private async Task OpenCustomRangeDialogAsync()
    {
        var parameters = new DialogParameters
        {
            ["InitialStart"] = _customStart,
            ["InitialEnd"] = _customEnd,
        };

        var dialogRef = await DialogService.ShowAsync<Dialogs.DateRangePickerDialog>(
            "Select Date Range",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });

        var result = await dialogRef.Result;
        if (result == null)
            return;
        if (result.Canceled)
            return;

        if (result.Data is IDictionary<string, object> data
            && data.TryGetValue("Start", out var start)
            && data.TryGetValue("End", out var end)
            && start is DateTime startDate
            && end is DateTime endDate)
        {
            _customStart = startDate;
            _customEnd = endDate;
            _range = "custom";
            await RefreshAsync();
        }
    }

    private Task RefreshAsync() => LoadDataAsync(showLoader: true);

    private async Task LoadDataAsync(bool showLoader)
    {
        var cts = new CancellationTokenSource();
        var previous = Interlocked.Exchange(ref _loadCts, cts);
        previous?.Cancel();
        previous?.Dispose();

        if (showLoader)
            _loading = true;

        _loadError = null;

        if (_range == "custom" && (!_customStart.HasValue || !_customEnd.HasValue))
        {
            _loading = false;
            _loadError = "Select start and end dates for custom range.";
            return;
        }

        var customQuery = string.Empty;
        if (_range == "custom" && _customStart.HasValue && _customEnd.HasValue)
        {
            customQuery = $"&start={Uri.EscapeDataString(_customStart.Value.ToUniversalTime().ToString("o"))}" +
                          $"&end={Uri.EscapeDataString(_customEnd.Value.ToUniversalTime().ToString("o"))}";
        }

        var url = $"api/dashboard/stats/get?type={_range}&utc=true{customQuery}&node={Uri.EscapeDataString(_node)}";
        var result = await Api.GetAsync<DashboardStatsResponse>(url, cts.Token);

        if (cts.IsCancellationRequested)
            return;

        if (result.IsOk && result.Data?.Stats is not null)
        {
            _response = result.Data;
            BuildCharts(result.Data);
            await LoadTopStatsFallbackAsync(cts.Token);
        }
        else if (result.IsInvalidToken)
        {
            await SessionService.ClearSessionAsync();
        }
        else
        {
            _loadError = result.DisplayError;
            Snackbar.Add(result.DisplayError, Severity.Error);
        }

        if (ReferenceEquals(_loadCts, cts))
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadTopStatsFallbackAsync(CancellationToken ct)
    {
        if (_response is null)
            return;

        if (_response.TopClients?.Count == 0)
        {
            var topClients = await FetchTopStatsAsync("TopClients", ct);
            if (topClients?.TopClients is { Count: > 0 })
                _response.TopClients = topClients.TopClients;
        }

        if (_response.TopDomains?.Count == 0)
        {
            var topDomains = await FetchTopStatsAsync("TopDomains", ct);
            if (topDomains?.TopDomains is { Count: > 0 })
                _response.TopDomains = topDomains.TopDomains;
        }

        if (_response.TopBlockedDomains?.Count == 0)
        {
            var topBlockedDomains = await FetchTopStatsAsync("TopBlockedDomains", ct);
            if (topBlockedDomains?.TopBlockedDomains is { Count: > 0 })
                _response.TopBlockedDomains = topBlockedDomains.TopBlockedDomains;
        }
    }

    private async Task<TopStatsResponse?> FetchTopStatsAsync(string statsType, CancellationToken ct)
    {
        var customQuery = string.Empty;
        if (_range == "custom" && _customStart.HasValue && _customEnd.HasValue)
        {
            customQuery = $"&start={Uri.EscapeDataString(_customStart.Value.ToUniversalTime().ToString("o"))}" +
                          $"&end={Uri.EscapeDataString(_customEnd.Value.ToUniversalTime().ToString("o"))}";
        }

        var url = $"api/dashboard/stats/getTop?statsType={Uri.EscapeDataString(statsType)}&type={_range}&limit=20&node={Uri.EscapeDataString(_node)}{customQuery}";
        var result = await Api.GetAsync<TopStatsResponse>(url, ct);

        return result.IsOk ? result.Data : null;
    }

    private void BuildCharts(DashboardStatsResponse statsResponse)
    {
        _lineLabels = statsResponse.MainChartData?.Labels.ToArray() ?? [];

        if (statsResponse.MainChartData?.Datasets is { Count: > 0 })
        {
            _lineSeries = statsResponse.MainChartData.Datasets
                .Where(ds => ds.Data.Count > 0)
                .Select(ds => new ChartSeries<double>
                {
                    Name = string.IsNullOrWhiteSpace(ds.Label) ? "Series" : ds.Label,
                    Data = ds.Data.Select(v => (double)v).ToArray()
                })
                .ToList();
        }
        else
        {
            _lineSeries = [];
        }

        static (double[] Data, string[] Labels) ToPie(DashboardChartData? chart)
        {
            if (chart == null || chart?.Datasets.Count == 0 || chart?.Labels.Count == 0)
                return ([], []);

            var values = chart.Datasets[0].Data;
            var count = Math.Min(values.Count, chart.Labels.Count);
            return (values.Take(count).Select(v => (double)v).ToArray(), chart.Labels.Take(count).ToArray());
        }

        (_pie1Data, _pie1Labels) = ToPie(statsResponse.QueryResponseChartData);
        (_pie2Data, _pie2Labels) = ToPie(statsResponse.QueryTypeChartData);
        (_pie3Data, _pie3Labels) = ToPie(statsResponse.ProtocolTypeChartData);
    }

    private async Task ShowTopStatsAsync(string statsType)
    {
        var parameters = new DialogParameters
        {
            ["StatsType"] = statsType,
            ["Range"] = _range,
            ["Node"] = _node,
        };

        await DialogService.ShowAsync<Dialogs.TopStatsDialog>(
            statsType.Replace("Top", "Top "),
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
    }

    private void QueryClient(string client)
        => Snackbar.Add($"Navigate to DNS Client to query {client}", Severity.Info);

    private void QueryDomain(string domain)
        => Snackbar.Add($"Navigate to DNS Client to query {domain}", Severity.Info);

    private string GetSelectedRangeLabel()
    {
        if (_range == "custom" && _customStart.HasValue && _customEnd.HasValue)
            return $"{_customStart:MMM d, yyyy HH:mm} → {_customEnd:MMM d, yyyy HH:mm}";

        return "Last Hour";
    }

    private static string DisplayName(TopStatsEntry entry)
        => string.IsNullOrWhiteSpace(entry.NameIdn) ? entry.Name : entry.NameIdn;

    private static bool HasPieData(double[] data, string[] labels)
        => labels.Length > 0 && data.Length > 0 && data.Any(v => v > 0d);

    public void Dispose()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
    }
}
