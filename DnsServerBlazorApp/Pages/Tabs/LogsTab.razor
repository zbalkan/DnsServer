@inject ApiService     Api
@inject SessionService SessionService
@inject ISnackbar      Snackbar
@inject IJSRuntime     JS

<MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="false"
         PanelClass="pt-2" SliderColor="Color.Primary">

    @* ── Log Files tab ── *@
    <MudTabPanel Text="Log Files">
        <div style="display:flex;gap:12px;height:calc(100vh - 260px);">

            @* Left: file list *@
            <MudPaper Elevation="1" Style="width:260px;min-width:180px;display:flex;flex-direction:column;">
                <div class="pa-2" style="display:flex;align-items:center;gap:6px;border-bottom:1px solid rgba(0,0,0,.12);">
                    <MudText Typo="Typo.subtitle2" Style="flex:1">Log Files</MudText>
                    @if (SessionService.CanModify("Logs"))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" Size="Size.Small"
                                       Color="Color.Error" Title="Delete all logs"
                                       OnClick="DeleteAllLogsAsync" />
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                   OnClick="LoadFileListAsync" Title="Refresh" />
                </div>
                <div style="overflow-y:auto;flex:1;">
                    @if (_loadingFiles)
                    {
                        <div style="display:flex;justify-content:center;padding:20px;">
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                        </div>
                    }
                    else
                    {
                        @foreach (var f in _logFiles)
                        {
                            <div style="display:flex;align-items:center;padding:3px 8px;cursor:pointer;
                                        background:@(_selectedFile == f.FileName ? "rgba(102,153,255,.15)" : "transparent");"
                                 @onclick="@(() => _selectedFile = f.FileName)">
                                <MudText Typo="Typo.body2" Style="flex:1;word-break:break-all;">
                                    @f.FileName
                                    @if (!string.IsNullOrEmpty(f.Size))
                                    { <MudText Typo="Typo.caption" Style="margin-left:4px;opacity:.6;">(@f.Size)</MudText> }
                                </MudText>
                                @if (SessionService.CanModify("Logs"))
                                {
                                    <span @onclick:stopPropagation="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => DeleteLogAsync(f.FileName))" />
                                    </span>
                                }
                            </div>
                        }
                    }
                </div>
            </MudPaper>

            @* Right: download panel *@
            <MudPaper Elevation="1" Style="flex:1;display:flex;flex-direction:column;min-width:0;">
                <div class="pa-2" style="display:flex;align-items:center;gap:6px;border-bottom:1px solid rgba(0,0,0,.12);">
                    <MudText Typo="Typo.subtitle2" Style="flex:1">@(_selectedFile ?? "Select a log file")</MudText>
                    @if (_selectedFile is not null)
                    {
                        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick="DownloadLogAsync">Download / View</MudButton>
                    }
                </div>
                <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:24px;text-align:center;">
                    @if (_selectedFile is null)
                    {
                        <MudText Typo="Typo.body2" Style="opacity:.5;">Select a file from the list to download it.</MudText>
                    }
                    else
                    {
                        <div>
                            <MudIcon Icon="@Icons.Material.Filled.Description" Style="font-size:48px;opacity:.3;" />
                            <MudText Typo="Typo.body1" Class="mt-2">@_selectedFile</MudText>
                            <MudText Typo="Typo.body2" Style="opacity:.6;" Class="mt-1">
                                Click <strong>Download / View</strong> to open this log file.
                            </MudText>
                        </div>
                    }
                </div>
            </MudPaper>
        </div>
    </MudTabPanel>

    @* ── Query Logs tab ── *@
    <MudTabPanel Text="Query Logs" @ref="_queryLogsPanel">
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;margin-bottom:8px;">
            <MudSelect T="string" @bind-Value="_queryAppName" Label="App" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Style="max-width:200px;"
                       ValueChanged="OnQueryAppChanged">
                @foreach (var a in _queryLogApps)
                {
                    <MudSelectItem Value="@a.Name">@a.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" @bind-Value="_queryClassPath" Label="Class Path" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Style="max-width:260px;"
                       Disabled="@(string.IsNullOrEmpty(_queryAppName))">
                @foreach (var c in _queryLogClasses)
                {
                    <MudSelectItem Value="@c.ClassPath">@c.ClassPath</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_qSearch" Label="Domain filter" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Style="max-width:280px;" />
            <MudTextField @bind-Value="_qClient" Label="Client IP filter" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Style="max-width:200px;" />
            <MudSelect T="string" @bind-Value="_qProtocol" Label="Protocol" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Style="max-width:120px;">
                <MudSelectItem Value="@("")">All</MudSelectItem>
                <MudSelectItem Value="@("UDP")">UDP</MudSelectItem>
                <MudSelectItem Value="@("TCP")">TCP</MudSelectItem>
                <MudSelectItem Value="@("HTTPS")">HTTPS</MudSelectItem>
                <MudSelectItem Value="@("TLS")">TLS</MudSelectItem>
                <MudSelectItem Value="@("QUIC")">QUIC</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(_qLoading || string.IsNullOrEmpty(_queryAppName) || string.IsNullOrEmpty(_queryClassPath))"
                       OnClick="QueryLogsAsync">Search</MudButton>
        </div>

        @if (_qLoading)
        {
            <div style="display:flex;justify-content:center;padding:40px;">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (_qLogs.Count > 0)
        {
            <MudTable Items="@_qLogs" Dense="true" Hover="true" Elevation="1"
                      FixedHeader="true" Height="calc(100vh - 340px)">
                <HeaderContent>
                    <MudTh>Time</MudTh>
                    <MudTh>Client</MudTh>
                    <MudTh>Protocol</MudTh>
                    <MudTh>Domain</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Response</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Time">@context.Timestamp.ToLocalTime().ToString("HH:mm:ss")</MudTd>
                    <MudTd DataLabel="Client">@context.ClientIpAddress</MudTd>
                    <MudTd DataLabel="Protocol">@context.Protocol</MudTd>
                    <MudTd DataLabel="Domain">@context.Qname</MudTd>
                    <MudTd DataLabel="Type">@context.Qtype</MudTd>
                    <MudTd DataLabel="Response">
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.Rcode == "NOERROR" ? Color.Success : Color.Error)"
                                 Variant="Variant.Filled">@context.Rcode</MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>
</MudTabs>

@code {
    // ── Log files ──────────────────────────────────────────────────────
    private bool          _loadingFiles = true;
    private string?       _selectedFile;
    private List<LogFile> _logFiles     = [];

    // ── Query logs ─────────────────────────────────────────────────────
    private MudTabPanel? _queryLogsPanel;
    private bool         _qLoading;
    private string       _qSearch      = string.Empty;
    private string       _qClient      = string.Empty;
    private string       _qProtocol    = string.Empty;
    private List<QueryLogEntry> _qLogs = [];

    // App + classPath selectors for query logs
    private List<DnsApp>      _queryLogApps    = [];
    private List<DnsAppClass> _queryLogClasses = [];
    private string            _queryAppName    = string.Empty;
    private string            _queryClassPath  = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadFileListAsync(), LoadQueryAppsAsync());
    }

    private async Task LoadFileListAsync()
    {
        _loadingFiles = true;
        var result = await Api.GetAsync<LogFilesResponse>("api/logs/list");
        _loadingFiles = false;

        if (result.IsOk && result.Data?.LogFiles is { } list)
            _logFiles = list;
        else
            Snackbar.Add(result.DisplayError, Severity.Error);
    }

    private async Task DownloadLogAsync()
    {
        if (_selectedFile is null) return;
        var url = Api.BuildDownloadUrl($"api/logs/download?fileName={Uri.EscapeDataString(_selectedFile)}");
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task DeleteLogAsync(string fileName)
    {
        var form = new Dictionary<string, string> { ["fileName"] = fileName };
        var res = await Api.PostAsync<object>("api/logs/delete", form);
        if (res.IsOk)
        {
            if (_selectedFile == fileName) _selectedFile = null;
            await LoadFileListAsync();
        }
        else
            Snackbar.Add(res.DisplayError, Severity.Error);
    }

    private async Task DeleteAllLogsAsync()
    {
        var res = await Api.PostAsync<object>("api/logs/deleteAll", new Dictionary<string, string>());
        if (res.IsOk)
        {
            _selectedFile = null;
            _logFiles.Clear();
            Snackbar.Add("All logs deleted.", Severity.Success);
        }
        else
            Snackbar.Add(res.DisplayError, Severity.Error);
    }

    // ── Query Logs ─────────────────────────────────────────────────────
    private async Task LoadQueryAppsAsync()
    {
        var result = await Api.GetAsync<AppsListResponse>("api/apps/list");
        if (result.IsOk && result.Data?.Apps is { } apps)
        {
            _queryLogApps = apps
                .Where(a => a.DnsApps.Any(c => c.IsQueryLogs))
                .ToList();
        }
    }

    private void OnQueryAppChanged(string appName)
    {
        _queryAppName   = appName;
        _queryClassPath = string.Empty;
        _queryLogClasses = _queryLogApps
            .FirstOrDefault(a => a.Name == appName)
            ?.DnsApps.Where(c => c.IsQueryLogs).ToList()
            ?? [];

        if (_queryLogClasses.Count == 1)
            _queryClassPath = _queryLogClasses[0].ClassPath;
    }

    private async Task QueryLogsAsync()
    {
        _qLoading = true;
        var url = $"api/logs/query?name={Uri.EscapeDataString(_queryAppName)}" +
                  $"&classPath={Uri.EscapeDataString(_queryClassPath)}" +
                  (string.IsNullOrEmpty(_qSearch)   ? "" : $"&qname={Uri.EscapeDataString(_qSearch)}") +
                  (string.IsNullOrEmpty(_qClient)   ? "" : $"&clientIpAddress={Uri.EscapeDataString(_qClient)}") +
                  (string.IsNullOrEmpty(_qProtocol) ? "" : $"&protocol={_qProtocol}") +
                  "&entriesPerPage=200";

        var result = await Api.GetAsync<QueryLogsResponse>(url);
        _qLoading = false;

        if (result.IsOk && result.Data?.Entries is { } list)
            _qLogs = list;
        else
            Snackbar.Add(result.DisplayError, Severity.Error);
    }
}
