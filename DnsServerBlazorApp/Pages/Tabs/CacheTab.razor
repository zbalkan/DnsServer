@inject ApiService     Api
@inject SessionService SessionService
@inject ISnackbar      Snackbar

<MudPaper Elevation="1" Style="display:flex;flex-direction:column;height:calc(100vh - 200px);">
    <div class="pa-2" style="display:flex;align-items:center;gap:6px;border-bottom:1px solid rgba(0,0,0,.12);">
        <MudText Typo="Typo.subtitle2" Style="flex:1">Cached Zones</MudText>
        <ClusterNodeSelect Value="@_node" ValueChanged="OnNodeChangedAsync" />
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                       title="Refresh" OnClick="RefreshListAsync" />
        @if (SessionService.CanModify("Cache"))
        {
            <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" Size="Size.Small"
                           Color="Color.Error" title="Flush all cache"
                           OnClick="FlushAllAsync" />
        }
    </div>

    <div style="overflow-y:auto;flex:1;padding:4px;">
        @if (_loadingList)
        {
            <div style="display:flex;justify-content:center;padding:20px;">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_domain))
            {
                <div class="dns-zone-item" @onclick="NavigateUpAsync"
                     style="cursor:pointer;padding:4px 8px;">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Style="display:inline;margin-left:4px;">..</MudText>
                </div>
            }
            @foreach (var z in _subZones)
            {
                <div class="dns-zone-item" @onclick="@(() => DrillDownAsync(z))"
                     style="cursor:pointer;padding:4px 8px;border-radius:4px;" title="@z">
                    <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Style="display:inline;margin-left:4px;">@z</MudText>
                </div>
            }
            @if (!_loadingList && _subZones.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Default" Class="pa-4">No cached zones.</MudText>
            }
        }
    </div>

    @if (!string.IsNullOrEmpty(_domain) && SessionService.CanModify("Cache"))
    {
        <div class="pa-2" style="border-top:1px solid rgba(0,0,0,.12);display:flex;justify-content:flex-end;">
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteZoneAsync">Delete Zone "@_domain"</MudButton>
        </div>
    }
</MudPaper>

@code {
    private string  _node         = "cluster";
    private string  _domain       = string.Empty;
    private bool    _loadingList;
    private int     _loadVersion;
    private List<string> _subZones = [];

    protected override async Task OnInitializedAsync() => await RefreshListAsync();

    private async Task OnNodeChangedAsync(string v) { _node = v; await RefreshListAsync(); }

    private async Task RefreshListAsync() => await LoadListAsync(_domain);

    private async Task LoadListAsync(string domain)
    {
        var version = ++_loadVersion;
        _loadingList = true;
        var url = $"api/cache/list?domain={Uri.EscapeDataString(domain)}&node={Uri.EscapeDataString(_node)}";
        var result = await Api.GetAsync<Models.Cache.CacheListResponse>(url);

        if (_loadVersion != version) return; // discard stale response from concurrent navigation
        _loadingList = false;

        if (result.IsOk && result.Data is not null)
        {
            _domain   = domain;
            _subZones = result.Data.Zones ?? [];
        }
        else
            Snackbar.Add(result.DisplayError, Severity.Error);
    }

    private async Task DrillDownAsync(string sub)
    {
        var full = string.IsNullOrEmpty(_domain) ? sub : $"{sub}.{_domain}";
        await LoadListAsync(full);
    }

    private async Task NavigateUpAsync()
    {
        var parent = _domain.GetParentDomain();
        await LoadListAsync(parent);
    }

    private async Task DeleteZoneAsync()
    {
        if (string.IsNullOrEmpty(_domain)) return;
        var form = new Dictionary<string, string>
        {
            ["domain"] = _domain,
            ["node"]   = _node,
        };
        var res = await Api.PostAsync<object>("api/cache/delete", form);
        if (res.IsOk)
        {
            Snackbar.Add($"Cached zone '{_domain}' deleted.", Severity.Success);
            await LoadListAsync(_domain.GetParentDomain());
        }
        else
            Snackbar.Add(res.DisplayError, Severity.Error);
    }

    private async Task FlushAllAsync()
    {
        var form = new Dictionary<string, string> { ["node"] = _node };
        var res = await Api.PostAsync<object>("api/cache/flush", form);
        if (res.IsOk)
        {
            Snackbar.Add("Cache flushed.", Severity.Success);
            _domain = string.Empty;
            await LoadListAsync(string.Empty);
        }
        else
            Snackbar.Add(res.DisplayError, Severity.Error);
    }

}
